# FlipJump Interpreter — environment configuration
# Copy this file to .env.local and adjust paths for your installation.

# Server
PORT=3000
HOSTNAME=localhost

# Comma-separated allowlist of WebSocket origins. Defaults to localhost +
# fj.tomhe.app — extend for other deploy hosts.
# ALLOWED_ORIGINS=https://example.com,https://staging.example.com

# Set to 1 when running behind a reverse proxy that strips and re-adds
# X-Forwarded-For. Without it, the raw socket address is used so per-IP
# rate limits cannot be bypassed by spoofing the header.
#
# IMPORTANT: the server reads the leftmost XFF entry. Your proxy MUST strip
# (not append to) any client-supplied X-Forwarded-For before forwarding, e.g.:
#   nginx:  proxy_set_header X-Forwarded-For $remote_addr;              ← correct
#   nginx:  proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for; ← NOT safe
# If the proxy appends, the leftmost entry is attacker-controlled and defeats
# per-IP rate limiting.
# TRUST_PROXY=1

# REST API rate limit — max requests per IP per 60-second window.
# Default: 20. Override for staging / load testing.
# API_RATE_LIMIT=20

# Tool commands — set these to the correct paths/commands for your environment.
# Defaults assume the CLIs are on PATH (e.g. via `pip install flipjump c2fj`).

# Main FlipJump CLI (from `pip install flipjump`).
#   fj <file.fj> [<file2.fj>…]            → assemble and run (default)
#   fj --asm <files…> -o <output.fjm>     → assemble only, save FJM
#   fj --run <file.fjm>                   → run a compiled FJM
FJ_CMD=fj

# Brainfuck → FlipJump converter.
#   bf2fj <input.bf> -o <output.fj>
BF2FJ_CMD=bf2fj

# C → FlipJump converter (requires `make` + a RISC-V toolchain on PATH).
#   c2fj --build-dir <dir> --unify-fj --finish-after fj <input.c>
#   Produces <dir>/unified.fj.
C2FJ_CMD=c2fj
