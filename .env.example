# FlipJump Interpreter — environment configuration
# Copy this file to .env.local and adjust paths for your installation.

# Server
PORT=3000
HOSTNAME=localhost

# Tool commands — set these to the correct paths/commands for your environment.
# Default values shown below.

# Main FlipJump CLI (from `pip install flipjump`)
# Expected interface:
#   fj asm <files...> -o <output.fjm>   → assemble FJ source to binary
#   fj run <file.fjm>                    → execute a compiled FJM binary
#   fj asm_run <files...>                → assemble and run in one step
FJ_CMD=fj

# Brainfuck → FlipJump converter
# Expected interface:  bf2fj <input.bf> <output.fj>
BF2FJ_CMD=bf2fj

# C → FlipJump converter
# Expected interface:  c2fj <input.(c|dir)> -o <output.fj>
C2FJ_CMD=c2fj
